---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingNav from "../components/LandingNav.astro";
import { HeroCalculatorIsland } from "@/islands/HeroCalculatorIsland";
---

<BaseLayout
  title="EuroVisaCalculator — Schengen 90/180 Day Tracker"
  description="Track your Schengen visa allowance across multiple travelers. Free, no account required. Official EU rolling-window algorithm."
>
  <LandingNav />

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="hero">
    <!-- Left column — static copy -->
    <div class="hero__left">
      <!-- Eyebrow badge -->
      <div class="eyebrow">
        <span class="eyebrow__dot"></span>
        Free · No account required
      </div>

      <!-- Heading -->
      <h1 class="hero__h1">
        Know exactly how long you can <em>stay in Europe.</em>
      </h1>

      <!-- Sub-copy -->
      <p class="hero__sub">
        Track your 90-day Schengen allowance across multiple travelers. Add
        trips, see remaining days, and plan without guessing.
      </p>

      <!-- Proof items -->
      <div class="proof-items">
        <span class="proof-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 1L9.8 5.8L15 6.2L11.2 9.6L12.4 15L8 12.4L3.6 15L4.8 9.6L1 6.2L6.2 5.8L8 1Z" />
          </svg>
          Official EU rolling-window algorithm
        </span>
        <span class="proof-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 8C2 4.686 4.686 2 8 2s6 2.686 6 6-2.686 6-6 6-6-2.686-6-6z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M5.5 8l2 2L11 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Multiple travelers, one view
        </span>
        <span class="proof-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 2v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M2 8C2 4.686 4.686 2 8 2s6 2.686 6 6-2.686 6-6 6-6-2.686-6-6z" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          URL-shareable results
        </span>
      </div>
    </div>

    <!-- Right column — interactive calculator card -->
    <div class="hero__right">
      <HeroCalculatorIsland client:visible />
    </div>
  </section>

  <!-- ── TRUST STRIP ──────────────────────────────────────────────────────── -->
  <section class="trust-strip" aria-label="Key statistics">
    <div class="trust-strip__grid">
      <div class="trust-stat">
        <span class="trust-stat__num">90</span>
        <span class="trust-stat__label">days allowed<br />in any 180-day window</span>
      </div>
      <div class="trust-stat">
        <span class="trust-stat__num">4+</span>
        <span class="trust-stat__label">travelers tracked<br />simultaneously</span>
      </div>
      <div class="trust-stat">
        <span class="trust-stat__num">26</span>
        <span class="trust-stat__label">Schengen countries<br />using the same rule</span>
      </div>
      <div class="trust-stat">
        <span class="trust-stat__num">0</span>
        <span class="trust-stat__label">accounts required<br />to get started</span>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ─────────────────────────────────────────────────────── -->
  <section id="how" class="how">
    <div class="how__inner">
      <p class="section-tag">How it works</p>
      <h2 class="section-heading">
        Simple enough to use<br />
        in <em>thirty seconds.</em>
      </h2>
      <p class="section-sub">
        No spreadsheets. No manual math. Just add your trips and get a clear answer.
      </p>

      <div class="steps-grid">
        <!-- Step 01 -->
        <div class="step-card">
          <span class="step-card__num">01</span>
          <div class="step-card__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M4 17c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="step-card__title">Add your travelers</h3>
          <p class="step-card__desc">Enter names for everyone you want to track — yourself, a partner, family members. Each person gets their own column.</p>
        </div>
        <!-- Step 02 -->
        <div class="step-card step-card--border-left">
          <span class="step-card__num">02</span>
          <div class="step-card__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="3" y="4" width="14" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M3 9h14" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 2v4M13 2v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="step-card__title">Log entry &amp; exit dates</h3>
          <p class="step-card__desc">Add each Schengen trip with entry and exit dates. Mark ongoing trips with no exit date yet. Planned future trips show up too.</p>
        </div>
        <!-- Step 03 -->
        <div class="step-card step-card--border-left">
          <span class="step-card__num">03</span>
          <div class="step-card__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
              <path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="step-card__title">See remaining days instantly</h3>
          <p class="step-card__desc">Color-coded statuses update live. Green means safe, yellow means caution, red means at risk. Share the link with your travel partner.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero layout ────────────────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    padding-top: 32px;
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Left column ────────────────────────────────────────────────────────── */
  .hero__left {
    padding: 60px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 28px;
  }

  @media (min-width: 768px) {
    .hero__left {
      padding: 80px 80px;
    }
  }

  /* ── Right column ──────────────────────────────────────────────────────── */
  .hero__right {
    background: var(--color-white);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
    min-height: 400px;
  }

  @media (min-width: 768px) {
    .hero__right {
      border-top: none;
      border-left: 1px solid var(--color-border);
      padding: 80px 60px;
      min-height: auto;
    }
  }

  /* ── Eyebrow badge ──────────────────────────────────────────────────────── */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-green);
    background: var(--color-green-bg);
    padding: 5px 14px;
    border-radius: 100px;
    width: fit-content;
    border: 1px solid var(--color-green-border);
    animation: fadeUp 0.5s 0.1s both ease-out;
  }

  .eyebrow__dot {
    width: 7px;
    height: 7px;
    background: var(--color-green);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Heading ────────────────────────────────────────────────────────────── */
  .hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4.5vw, 3.8rem);
    font-weight: 400;
    line-height: 1.12;
    color: var(--color-navy);
    letter-spacing: -0.01em;
    margin: 0;
    animation: fadeUp 0.6s 0.2s both ease-out;
  }

  .hero__h1 em {
    font-style: italic;
    color: var(--color-green);
  }

  /* ── Sub-copy ───────────────────────────────────────────────────────────── */
  .hero__sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-soft);
    max-width: 440px;
    margin: 0;
    animation: fadeUp 0.6s 0.3s both ease-out;
  }

  /* ── Proof items ────────────────────────────────────────────────────────── */
  .proof-items {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.4s both ease-out;
  }

  .proof-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-text-soft);
  }

  .proof-item svg {
    color: var(--color-green);
    flex-shrink: 0;
  }

  /* ── Shared fade-up animation ───────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Trust strip ────────────────────────────────────────────────────────── */
  .trust-strip {
    background: var(--color-navy);
    padding: 60px 24px;
    position: relative;
    overflow: hidden;
  }

  .trust-strip::before {
    content: "";
    position: absolute;
    top: -150px;
    left: -150px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 185, 107, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .trust-strip {
      padding: 100px 80px;
    }
  }

  .trust-strip__grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .trust-strip__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
  }

  .trust-stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .trust-stat__num {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 400;
    color: var(--color-white);
    line-height: 1;
  }

  .trust-stat__label {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  /* ── Shared section typography ──────────────────────────────────────────── */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    margin: 0 0 16px;
  }

  .section-tag::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--color-green);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-navy);
    letter-spacing: -0.01em;
    margin: 0 0 16px;
  }

  .section-heading em { font-style: italic; }

  .section-heading--light { color: var(--color-white); }

  .section-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-soft);
    max-width: 520px;
    margin: 0;
  }

  .section-sub--light { color: rgba(255, 255, 255, 0.6); }

  /* ── How it works ───────────────────────────────────────────────────────── */
  .how {
    padding: 60px 24px;
  }

  @media (min-width: 768px) {
    .how {
      padding: 100px 80px;
    }
  }

  .how__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    margin-top: 60px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    gap: 2px;
    background: var(--color-border);
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .step-card {
    background: var(--color-white);
    padding: 40px 36px;
    transition: background 0.2s;
  }

  .step-card:hover { background: #FAFBFD; }

  .step-card--border-left {
    /* On mobile the gap handles separation; on desktop show left border */
  }

  @media (min-width: 768px) {
    .step-card--border-left {
      border-left: none; /* gap + background trick handles it */
    }
  }

  .step-card__num {
    display: block;
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-soft);
    line-height: 1;
    margin-bottom: 16px;
  }

  .step-card__icon {
    width: 44px;
    height: 44px;
    background: var(--color-green-bg);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-green);
    margin-bottom: 20px;
  }

  .step-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-navy);
    margin: 0 0 10px;
  }

  .step-card__desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-soft);
    line-height: 1.7;
    margin: 0;
  }
</style>
