---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingNav from "../components/LandingNav.astro";
import { HeroCalculatorIsland } from "@/islands/HeroCalculatorIsland";
---

<BaseLayout
  title="EuroVisaCalculator — Schengen 90/180 Day Tracker"
  description="Track your Schengen visa allowance across multiple travelers. Free, no account required. Official EU rolling-window algorithm."
>
  <LandingNav />

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="hero">
    <!-- Left column — static copy -->
    <div class="hero__left">
      <!-- Eyebrow badge -->
      <div class="eyebrow">
        <span class="eyebrow__dot"></span>
        Free · No account required
      </div>

      <!-- Heading -->
      <h1 class="hero__h1">
        Know exactly how long you can <em>stay in Europe.</em>
      </h1>

      <!-- Sub-copy -->
      <p class="hero__sub">
        Track your 90-day Schengen allowance across multiple travelers. Add
        trips, see remaining days, and plan without guessing.
      </p>

      <!-- Proof items -->
      <div class="proof-items">
        <span class="proof-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 1L9.8 5.8L15 6.2L11.2 9.6L12.4 15L8 12.4L3.6 15L4.8 9.6L1 6.2L6.2 5.8L8 1Z" />
          </svg>
          Official EU rolling-window algorithm
        </span>
        <span class="proof-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 8C2 4.686 4.686 2 8 2s6 2.686 6 6-2.686 6-6 6-6-2.686-6-6z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M5.5 8l2 2L11 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Multiple travelers, one view
        </span>
        <span class="proof-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 2v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M2 8C2 4.686 4.686 2 8 2s6 2.686 6 6-2.686 6-6 6-6-2.686-6-6z" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          URL-shareable results
        </span>
      </div>
    </div>

    <!-- Right column — interactive calculator card -->
    <div class="hero__right">
      <HeroCalculatorIsland client:visible />
    </div>
  </section>

  <!-- ── TRUST STRIP ──────────────────────────────────────────────────────── -->
  <section class="trust-strip" aria-label="Key statistics">
    <div class="trust-strip__grid">
      <div class="trust-stat">
        <span class="trust-stat__num">90</span>
        <span class="trust-stat__label">days allowed<br />in any 180-day window</span>
      </div>
      <div class="trust-stat">
        <span class="trust-stat__num">4+</span>
        <span class="trust-stat__label">travelers tracked<br />simultaneously</span>
      </div>
      <div class="trust-stat">
        <span class="trust-stat__num">26</span>
        <span class="trust-stat__label">Schengen countries<br />using the same rule</span>
      </div>
      <div class="trust-stat">
        <span class="trust-stat__num">0</span>
        <span class="trust-stat__label">accounts required<br />to get started</span>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ─────────────────────────────────────────────────────── -->
  <section id="how" class="how">
    <div class="how__inner">
      <p class="section-tag">How it works</p>
      <h2 class="section-heading">
        Simple enough to use<br />
        in <em>thirty seconds.</em>
      </h2>
      <p class="section-sub">
        No spreadsheets. No manual math. Just add your trips and get a clear answer.
      </p>

      <div class="steps-grid">
        <!-- Step 01 -->
        <div class="step-card">
          <span class="step-card__num">01</span>
          <div class="step-card__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M4 17c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="step-card__title">Add your travelers</h3>
          <p class="step-card__desc">Enter names for everyone you want to track — yourself, a partner, family members. Each person gets their own column.</p>
        </div>
        <!-- Step 02 -->
        <div class="step-card step-card--border-left">
          <span class="step-card__num">02</span>
          <div class="step-card__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="3" y="4" width="14" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M3 9h14" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 2v4M13 2v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="step-card__title">Log entry &amp; exit dates</h3>
          <p class="step-card__desc">Add each Schengen trip with entry and exit dates. Mark ongoing trips with no exit date yet. Planned future trips show up too.</p>
        </div>
        <!-- Step 03 -->
        <div class="step-card step-card--border-left">
          <span class="step-card__num">03</span>
          <div class="step-card__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
              <path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="step-card__title">See remaining days instantly</h3>
          <p class="step-card__desc">Color-coded statuses update live. Green means safe, yellow means caution, red means at risk. Share the link with your travel partner.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURES ─────────────────────────────────────────────────────────── -->
  <section id="features" class="features">
    <div class="features__inner">
      <!-- Left column -->
      <div class="features__left">
        <p class="section-tag section-tag--light">Features</p>
        <h2 class="section-heading section-heading--light">
          Built for people with<br />
          <em>complex travel patterns.</em>
        </h2>
        <p class="section-sub section-sub--light">
          Most Schengen calculators only handle a single traveler on a single
          trip. We built this because we needed something better.
        </p>
        <a href="https://eurovisacalculator.com/app" class="btn-green" style="margin-top:36px;display:inline-flex;">
          Try it free →
        </a>
      </div>

      <!-- Right column — feature list -->
      <div class="features__right">
        <div class="feature-item">
          <div class="feature-item__icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M2 9C2 5.134 5.134 2 9 2s7 3.134 7 7-3.134 7-7 7-7-3.134-7-7z" stroke="currentColor" stroke-width="1.4"/>
              <path d="M5.5 9l2.5 2.5L13 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="feature-item__title">Official rolling-window algorithm</p>
            <p class="feature-item__desc">We implement the exact EU calculation: any 180-day lookback window, counting both entry and exit days. Verified against the official EU calculator.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-item__icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
              <rect x="10" y="2" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
              <rect x="2" y="10" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
              <rect x="10" y="10" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            </svg>
          </div>
          <div>
            <p class="feature-item__title">Multiple travelers, one dashboard</p>
            <p class="feature-item__desc">Track couples, families, or groups with different schedules in a single shared view. Columns per traveler, shareable via URL.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-item__icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M9 2v4M9 12v4M2 9h4M12 9h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              <circle cx="9" cy="9" r="3" stroke="currentColor" stroke-width="1.4"/>
            </svg>
          </div>
          <div>
            <p class="feature-item__title">Earliest return date calculator</p>
            <p class="feature-item__desc">After leaving, see the earliest date you can return for a given number of days. Stops you booking flights that will get rejected at the border.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-item__icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3 15l4-4 3 3 5-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="feature-item__title">Date picker with live feedback</p>
            <p class="feature-item__desc">Calendar cells are color-coded as you pick dates — green for safe, yellow for caution, red for overstay. No surprises after you click confirm.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-item__icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M2 9.5l5-5 3 4 3-3 3 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="feature-item__title">Trip validation &amp; overstay warnings</p>
            <p class="feature-item__desc">Alerts fire before you save a trip that would push you over the limit. Overlapping dates are caught automatically.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── RULES EXPLAINER ──────────────────────────────────────────────────── -->
  <section id="rules" class="rules">
    <div class="rules__inner">
      <!-- Left: text -->
      <div class="rules__text">
        <p class="section-tag">The 90/180 Rule</p>
        <h2 class="section-heading">
          It's not "90 days<br />
          then leave for 90." <em>It's more complex.</em>
        </h2>
        <p class="section-sub">
          The rule applies to a <strong>rolling 180-day window</strong> — not
          fixed half-years. At any given moment, look back 180 days. If you've
          spent 90 or more days in Schengen during that window, you cannot enter.
        </p>
        <p class="rules__body">
          This means days "roll off" your count as time passes, which can free
          up allowance earlier than most travelers expect — but also means
          miscalculations happen easily.
        </p>
        <a href="https://eurovisacalculator.com/app" class="btn-green" style="margin-top:32px;display:inline-flex;">
          Calculate my days →
        </a>
      </div>

      <!-- Right: demo card -->
      <div class="allowance-card">
        <!-- Card header — mimics browser chrome -->
        <div class="allowance-card__header">
          <span class="traffic-dot traffic-dot--red"></span>
          <span class="traffic-dot traffic-dot--amber"></span>
          <span class="traffic-dot traffic-dot--green"></span>
          <span class="allowance-card__label">Traveler status · today</span>
        </div>

        <!-- Allowance bars -->
        <div class="allowance-bars">
          <!-- Emma — safe (43/90, 47 remaining) -->
          <div class="allowance-row">
            <span class="allowance-name">Emma</span>
            <div class="allowance-track" role="progressbar" aria-valuenow="43" aria-valuemax="90" aria-label="Emma: 43 of 90 days used">
              <div class="allowance-fill allowance-fill--safe" style="width:43%"></div>
            </div>
            <span class="allowance-badge allowance-badge--safe">47 days left</span>
          </div>
          <!-- Liam — caution (76/90, 14 remaining) -->
          <div class="allowance-row">
            <span class="allowance-name">Liam</span>
            <div class="allowance-track" role="progressbar" aria-valuenow="76" aria-valuemax="90" aria-label="Liam: 76 of 90 days used">
              <div class="allowance-fill allowance-fill--caution" style="width:76%"></div>
            </div>
            <span class="allowance-badge allowance-badge--caution">14 days left</span>
          </div>
          <!-- Sofia — danger (88/90, 2 remaining) -->
          <div class="allowance-row">
            <span class="allowance-name">Sofia</span>
            <div class="allowance-track" role="progressbar" aria-valuenow="88" aria-valuemax="90" aria-label="Sofia: 88 of 90 days used">
              <div class="allowance-fill allowance-fill--danger" style="width:88%"></div>
            </div>
            <span class="allowance-badge allowance-badge--danger">2 days left</span>
          </div>
        </div>

        <!-- Rule pills -->
        <div class="rule-pills">
          <span class="rule-pill">Rolling 180-day window</span>
          <span class="rule-pill">26 Schengen countries</span>
          <span class="rule-pill">Entry + exit days count</span>
          <span class="rule-pill">No fixed reset date</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA BAND ─────────────────────────────────────────────────────────── -->
  <section class="cta-band">
    <div class="cta-band__inner">
      <h2 class="cta-band__heading">
        Stop guessing.<br />
        Start tracking <em>in seconds.</em>
      </h2>
      <p class="cta-band__sub">
        Free, no account required. Add travelers, enter your trips, and share
        a link with your travel partner immediately.
      </p>
      <div class="cta-band__actions">
        <a href="https://eurovisacalculator.com/app" class="btn-green">
          Open the calculator →
        </a>
        <a href="#how" class="btn-ghost">
          How does it work?
        </a>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ────────────────────────────────────────────────────────────── -->
  <footer class="footer">
    <div class="footer__inner">
      <div class="footer__top">
        <span class="footer__brand">EuroVisaCalculator</span>
        <div class="footer__actions">
          <a
            href="https://ko-fi.com/ericluskjopson"
            class="footer__kofi"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
            </svg>
            Support this project
          </a>
          <nav class="footer__links" aria-label="Footer navigation">
            <a href="/privacy" class="footer__link">Privacy</a>
            <a href="/blog" class="footer__link">Blog</a>
            <a href="#how" class="footer__link">How it works</a>
            <a href="https://eurovisacalculator.com/app" class="footer__link">Calculator</a>
          </nav>
        </div>
      </div>
      <p class="footer__disclaimer">
        For informational use only. Always verify with official EU sources before
        making travel decisions.
        Not legal advice. Schengen rules apply to all non-EU/EEA nationals.
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero layout ────────────────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    padding-top: 32px;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  @media (min-width: 900px) {
    .hero {
      flex-direction: row;
    }
  }

  /* ── Left column ────────────────────────────────────────────────────────── */
  .hero__left {
    padding: 60px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 28px;
  }

  @media (min-width: 900px) {
    .hero__left {
      flex: 1;
      padding: 80px 80px;
    }
  }

  /* ── Right column ──────────────────────────────────────────────────────── */
  .hero__right {
    background: var(--color-white);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
  }

  @media (min-width: 900px) {
    .hero__right {
      flex: 1;
      border-top: none;
      border-left: 1px solid var(--color-border);
      padding: 80px 60px;
    }
  }

  /* ── Eyebrow badge ──────────────────────────────────────────────────────── */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-green);
    background: var(--color-green-bg);
    padding: 5px 14px;
    border-radius: 100px;
    width: fit-content;
    border: 1px solid var(--color-green-border);
    animation: fadeUp 0.5s 0.1s both ease-out;
  }

  .eyebrow__dot {
    width: 7px;
    height: 7px;
    background: var(--color-green);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Heading ────────────────────────────────────────────────────────────── */
  .hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4.5vw, 3.8rem);
    font-weight: 400;
    line-height: 1.12;
    color: var(--color-navy);
    letter-spacing: -0.01em;
    margin: 0;
    animation: fadeUp 0.6s 0.2s both ease-out;
  }

  .hero__h1 em {
    font-style: italic;
    color: var(--color-green);
  }

  /* ── Sub-copy ───────────────────────────────────────────────────────────── */
  .hero__sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-soft);
    max-width: 440px;
    margin: 0;
    animation: fadeUp 0.6s 0.3s both ease-out;
  }

  /* ── Proof items ────────────────────────────────────────────────────────── */
  .proof-items {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.4s both ease-out;
  }

  .proof-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-text-soft);
  }

  .proof-item svg {
    color: var(--color-green);
    flex-shrink: 0;
  }

  /* ── Shared fade-up animation ───────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Trust strip ────────────────────────────────────────────────────────── */
  .trust-strip {
    background: var(--color-navy);
    padding: 60px 24px;
    position: relative;
    overflow: hidden;
  }

  .trust-strip::before {
    content: "";
    position: absolute;
    top: -150px;
    left: -150px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 185, 107, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .trust-strip {
      padding: 100px 80px;
    }
  }

  .trust-strip__grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .trust-strip__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
  }

  .trust-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
  }

  .trust-stat__num {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 400;
    color: var(--color-green);
    line-height: 1;
  }

  .trust-stat__label {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  /* ── Shared section typography ──────────────────────────────────────────── */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-green);
    margin: 0 0 16px;
  }

  .section-tag::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--color-green);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-navy);
    letter-spacing: -0.01em;
    margin: 0 0 16px;
  }

  .section-heading em {
    font-style: italic;
    color: var(--color-green);
  }

  .section-heading--light { color: var(--color-white); }

  .section-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-soft);
    max-width: 520px;
    margin: 0;
  }

  .section-sub--light { color: rgba(255, 255, 255, 0.6); }

  /* ── How it works ───────────────────────────────────────────────────────── */
  .how {
    padding: 60px 24px;
  }

  @media (min-width: 768px) {
    .how {
      padding: 100px 80px;
    }
  }

  .how__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    margin-top: 60px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    gap: 2px;
    background: var(--color-border);
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .step-card {
    background: var(--color-white);
    padding: 40px 36px;
    transition: background 0.2s;
  }

  .step-card:hover { background: #FAFBFD; }

  .step-card--border-left {
    /* On mobile the gap handles separation; on desktop show left border */
  }

  @media (min-width: 768px) {
    .step-card--border-left {
      border-left: none; /* gap + background trick handles it */
    }
  }

  .step-card__num {
    display: block;
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-soft);
    line-height: 1;
    margin-bottom: 16px;
  }

