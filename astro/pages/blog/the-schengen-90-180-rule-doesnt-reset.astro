      let currentScenario: Scenario | null = null;
      let TL_START: Date, TL_END: Date, TL_TOTAL: number;

      const displayScenarios = showTabs ? SCENARIOS : [SCENARIOS[scenarioIdx]];

      function computeRange(trips: Trip[]) {
        const mn = trips.reduce((a, t) => (t.start < a ? t.start : a), trips[0].start);
        const mx = trips.reduce((a, t) => (t.end > a ? t.end : a), trips[0].end);
        return { start: addDays(mn, -PAD), end: addDays(mx, PAD) };
      }

      function countForPerson(trips: Trip[], windowEnd: Date, personKey: string) {
        const windowStart = addDays(windowEnd, -179);
        let count = 0;
        trips.filter((t) => t.person === personKey).forEach((t) => {
          const os = t.start > windowStart ? t.start : windowStart;
          const oe = t.end < windowEnd ? t.end : windowEnd;
          if (oe >= os) count += diffDays(os, oe) + 1;
        });
        return count;
      }

      function countAll(trips: Trip[], windowEnd: Date) {
        const windowStart = addDays(windowEnd, -179);
        let count = 0;
        trips.forEach((t) => {
          const os = t.start > windowStart ? t.start : windowStart;
          const oe = t.end < windowEnd ? t.end : windowEnd;
          if (oe >= os) count += diffDays(os, oe) + 1;
        });
        return count;
      }

      function renderStatsSingle(trips: Trip[], windowEnd: Date) {
        const days = countAll(trips, windowEnd);
        const remaining = Math.max(0, 90 - days);
        statsEl.innerHTML = `
          <div class="stats-single">
            <div class="stat-card">
              <div class="stat-label">Days in window</div>
              <div class="stat-val ${days > 90 ? "danger" : days > 70 ? "warn" : "ok"}">${days}</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Remaining allowance</div>
              <div class="stat-val ${remaining === 0 ? "danger" : remaining < 20 ? "warn" : "ok"}">${remaining}</div>
            </div>
          </div>`;
      }

      function renderStatsQuad(trips: Trip[], windowEnd: Date) {
        const cards = PERSONS.map((p) => {
          const days = countForPerson(trips, windowEnd, p.key);
          const remaining = Math.max(0, 90 - days);
          return `<div class="stat-card" style="border-left-color:${p.color}">
            <div class="stat-label" style="color:${p.color};font-weight:500;">${p.label}</div>
            <div class="stat-val ${days > 90 ? "danger" : days > 70 ? "warn" : "ok"}">${days} <span style="font-size:12px;font-weight:400;color:var(--color-text-secondary)">/ 90</span></div>
            <div class="stat-sublabel">${remaining === 0 ? "No allowance left" : `${remaining} days left`}</div>
          </div>`;
        }).join("");
        statsEl.innerHTML = `<div class="stats-quad">${cards}</div>`;
      }

      function drawTimeline(windowEnd: Date) {
        const sc = currentScenario!;
        const trips = sc.trips;
        const isQuad = sc.mode === "quad";
        const W = canvas.width;
        const mL = isQuad ? 68 : 10, mR = 10, mTop = 28;
        const tripH = 20, tripGap = 5;
        const plotW = W - mL - mR;
        const windowStart = addDays(windowEnd, -179);

        const xOf = (dt: Date) => mL + (diffDays(TL_START, dt) / TL_TOTAL) * plotW;

        let numRows: number;
        let getTripRow: (t: Trip, i: number) => number;

        if (isQuad) {
          numRows = PERSONS.length;
          getTripRow = (t) => PERSON_MAP[t.person as PersonKey]?.row ?? 0;
        } else {
          const rowAssign = new Array(trips.length).fill(0);
          const rowEnds: (Date | undefined)[] = [];
          numRows = 1;
          trips.forEach((t, i) => {
            let r = 0;
            while (rowEnds[r] !== undefined && rowEnds[r]! >= t.start) r++;
            rowAssign[i] = r;
            rowEnds[r] = t.end;
            if (r + 1 > numRows) numRows = r + 1;
          });
          getTripRow = (_, i) => rowAssign[i];
        }

        const totalTripH = numRows * tripH + (numRows - 1) * tripGap;
        const tripAreaTop = mTop + 20;
        const axisY = tripAreaTop + totalTripH + 16;
        canvas.height = axisY + 22;

        ctx.clearRect(0, 0, W, canvas.height);

        if (isQuad) {
          ctx.font = "500 11px var(--font-sans,sans-serif)";
          ctx.textAlign = "right";
          PERSONS.forEach((p) => {
            const ty = tripAreaTop + p.row * (tripH + tripGap);
            ctx.fillStyle = p.color;
            ctx.fillText(p.label, mL - 6, ty + tripH / 2 + 4);
          });
        }

        const refOver = isQuad
          ? PERSONS.some((p) => countForPerson(trips, windowEnd, p.key) > 90)
          : countAll(trips, windowEnd) > 90;

        const x0w = Math.max(mL, xOf(windowStart));
        const x1w = Math.min(W - mR, xOf(addDays(windowEnd, 1)));

        ctx.fillStyle = refOver
          ? isDark ? "rgba(163,45,45,0.18)" : "rgba(240,149,149,0.15)"
          : isDark ? "rgba(55,138,221,0.12)" : "rgba(55,138,221,0.08)";
        ctx.fillRect(x0w, mTop - 4, x1w - x0w, axisY - (mTop - 4));
        ctx.strokeStyle = refOver
          ? isDark ? "rgba(240,149,149,0.5)" : "rgba(163,45,45,0.35)"
          : isDark ? "rgba(55,138,221,0.4)"  : "rgba(55,138,221,0.35)";
        ctx.lineWidth = 1;
        ctx.strokeRect(x0w, mTop - 4, x1w - x0w, axisY - (mTop - 4));

        ctx.strokeStyle = isDark ? "rgba(255,255,255,0.12)" : "rgba(0,0,0,0.1)";
        ctx.lineWidth = 0.5;
        ctx.beginPath(); ctx.moveTo(mL, axisY); ctx.lineTo(W - mR, axisY); ctx.stroke();

        ctx.font = "11px var(--font-sans,sans-serif)";
        ctx.textAlign = "center";
        const cur = new Date(TL_START); cur.setDate(1);
        while (cur <= TL_END) {
          const x = xOf(cur);
          if (x >= mL && x <= W - mR) {
            ctx.strokeStyle = isDark ? "rgba(255,255,255,0.08)" : "rgba(0,0,0,0.07)";
            ctx.lineWidth = 0.5;
            ctx.beginPath(); ctx.moveTo(x, mTop - 4); ctx.lineTo(x, axisY); ctx.stroke();
            const lx = x + (plotW / TL_TOTAL) * 15;
            if (lx < W - mR - 5) {
              ctx.fillStyle = isDark ? "rgba(255,255,255,0.4)" : "rgba(0,0,0,0.4)";
              ctx.fillText(cur.toLocaleDateString("en-GB", { month: "short" }), lx, axisY + 12);
            }
          }
          cur.setMonth(cur.getMonth() + 1);
        }

        trips.forEach((t, i) => {
          const row = getTripRow(t, i);
          const ty = tripAreaTop + row * (tripH + tripGap);
          const x0 = xOf(t.start);
          const x1 = xOf(addDays(t.end, 1));
          const tw = Math.max(x1 - x0, 2);

          ctx.fillStyle = t.color;
          ctx.beginPath(); (ctx as any).roundRect(x0, ty, tw, tripH, 4); ctx.fill();

          const os = t.start > windowStart ? t.start : windowStart;
          const oe = t.end < windowEnd ? t.end : windowEnd;
          if (oe >= os) {
            const xa = xOf(os), xb = xOf(addDays(oe, 1));
            ctx.fillStyle = "rgba(255,255,255,0.22)";
            ctx.beginPath(); (ctx as any).roundRect(xa, ty, xb - xa, tripH, 4); ctx.fill();
          }

          ctx.fillStyle = "rgba(255,255,255,0.92)";
          ctx.font = "500 11px var(--font-sans,sans-serif)";
          ctx.textAlign = "center";
          if (tw > 44) ctx.fillText(t.label, x0 + tw / 2, ty + tripH / 2 + 4);
        });

        const xEnd = xOf(addDays(windowEnd, 1));
        ctx.strokeStyle = isDark ? "rgba(212,83,126,0.85)" : "#d4537e";
        ctx.lineWidth = 1.5;
        ctx.setLineDash([4, 3]);
        ctx.beginPath(); ctx.moveTo(xEnd, mTop - 4); ctx.lineTo(xEnd, axisY); ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = "#d4537e";
        ctx.font = "500 11px var(--font-sans,sans-serif)";
        ctx.textAlign = "center";
        const lx = Math.min(Math.max(xEnd, mL + 38), W - mR - 38);
        ctx.fillText("window end", lx, mTop - 8);
      }

      function setScenario(idx: number) {
        currentScenario = displayScenarios[idx];
        if (showTabs) {
          tabsEl.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((b, i) =>
            b.classList.toggle("active", i === idx)
          );
        }
        descEl.innerHTML = currentScenario.desc;

        const range = computeRange(currentScenario.trips);
        TL_START = range.start; TL_END = range.end; TL_TOTAL = diffDays(TL_START, TL_END);
        slider.min = "179"; slider.max = String(TL_TOTAL - 1);
        const def = diffDays(TL_START, currentScenario.windowDefault);
        slider.value = String(Math.min(Math.max(def, 179), TL_TOTAL - 1));

        canvas.width = Math.max(520, container.clientWidth - 42);
        const windowEnd = addDays(TL_START, parseInt(slider.value));
        drawTimeline(windowEnd);

        if (currentScenario.mode === "quad") {
          renderStatsQuad(currentScenario.trips, windowEnd);
        } else {
          renderStatsSingle(currentScenario.trips, windowEnd);
        }

        dateLabelEl.textContent = fmtDate(windowEnd);
      }

      if (showTabs) {
        const initialIdx = scenarioIdx;
        displayScenarios.forEach((sc, i) => {
          const btn = document.createElement("button");
          btn.className = "tab-btn" + (i === initialIdx ? " active" : "");
          btn.textContent = sc.label;
          btn.onclick = () => setScenario(i);
          tabsEl.appendChild(btn);
        });
        setScenario(initialIdx);
      } else {
        tabsEl.style.display = "none";
        setScenario(0);
      }

      slider.addEventListener("input", () => {
        const windowEnd = addDays(TL_START, parseInt(slider.value));
        drawTimeline(windowEnd);
        if (currentScenario!.mode === "quad") {
          renderStatsQuad(currentScenario!.trips, windowEnd);
        } else {
          renderStatsSingle(currentScenario!.trips, windowEnd);
        }
        dateLabelEl.textContent = fmtDate(windowEnd);
      });

      window.addEventListener("resize", () => {
        canvas.width = Math.max(520, container.clientWidth - 42);
        const windowEnd = addDays(TL_START, parseInt(slider.value));
        drawTimeline(windowEnd);
      });
    }

    document.querySelectorAll<HTMLElement>(".schengen-explorer[data-scenario]").forEach(initExplorer);
  })();
</script>

