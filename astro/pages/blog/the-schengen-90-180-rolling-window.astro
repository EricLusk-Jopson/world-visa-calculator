<script>
  (function () {
    const PAD = 195;
    function d(y: number, m: number, day: number) { return new Date(y, m - 1, day); }
    function addDays(dt: Date, n: number) { const r = new Date(dt); r.setDate(r.getDate() + n); return r; }
    function diffDays(a: Date, b: Date) { return Math.round((b.getTime() - a.getTime()) / 86400000); }
    function fmtDate(dt: Date) { return dt.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" }); }
    function fmtShort(dt: Date) {
      const M = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
      return M[dt.getMonth()] + " " + String(dt.getDate()).padStart(2, "0");
    }

    const PERSONS = [
      { key: "anna",   label: "Anna",   color: "#c46e1a", row: 0 },
      { key: "marcus", label: "Marcus", color: "#1d9e75", row: 1 },
      { key: "ilker",  label: "Ilker",  color: "#2e86c1", row: 2 },
      { key: "olivia", label: "Olivia", color: "#7b52c9", row: 3 },
    ] as const;
    type PersonKey = typeof PERSONS[number]["key"];
    const PERSON_MAP = Object.fromEntries(PERSONS.map((p) => [p.key, p])) as Record<PersonKey, typeof PERSONS[number]>;

    interface Trip { start: Date; end: Date; label: string; color: string; person: string; showLabel?: boolean; }

    const makeGroupTrips = (): Trip[] =>
      PERSONS.map((p) => ({ start: d(2025, 2, 1), end: d(2025, 3, 22), label: "Group trip", color: "#378add", person: p.key }));

    const RETURN_TRIPS: Trip[] = [
      { start: d(2025, 5, 3),  end: d(2025, 6, 11),  label: "Anna",   color: "#c46e1a", person: "anna"   },
      { start: d(2025, 7, 15), end: d(2025, 10, 12), label: "Marcus", color: "#1d9e75", person: "marcus" },
      { start: d(2025, 8, 1),  end: d(2025, 10, 29), label: "Ilker",  color: "#2e86c1", person: "ilker"  },
      { start: d(2025, 9, 19), end: d(2025, 12, 17), label: "Olivia", color: "#7b52c9", person: "olivia" },
    ];

    const COMBINED_TRIPS: Trip[] = [...makeGroupTrips(), ...RETURN_TRIPS];

    interface Scenario {
      id: string; label: string; mode: "single" | "quad";
      desc: string; trips: Trip[]; windowDefault: Date;
    }

    const SCENARIOS: Scenario[] = [
      {
        id: "s1", label: "Full allowance available", mode: "single",
        desc: "<strong>Patricia</strong> plans to arrive March 1st and visit the Schengen Area for 90 days. Move the slider to inspect her allowance and her days used before, during and after her trip.",
        trips: [{ start: d(2025, 3, 1), end: d(2025, 5, 29), label: "Patricia", color: "#378add", person: "p" }],
        windowDefault: d(2025, 2, 28),
      },
      {
        id: "s2", label: "90 days used. When can she return?", mode: "single",
        desc: "<strong>Patricia</strong> spent 90 days in the Schengen Area (Mar 1–May 29). Her trip is over and she wants to return as soon as possible. Drag the window forward past late August to watch her days free up one at a time, allowing her to return.",
        trips: [{ start: d(2025, 3, 1), end: d(2025, 5, 29), label: "Patricia", color: "#378add", person: "p" }],
        windowDefault: d(2025, 8, 28),
      },
      {
        id: "s3", label: "90 days out, 90 days back", mode: "single",
        desc: "<strong>Patricia</strong> spends 90 days (Mar 1–May 29), leaves for about 90 days, then returns Aug 28 believing her counter has reset. Drag the window to Aug 28. Her first trip is still almost entirely inside the window.",
        trips: [
          { start: d(2025, 3, 1),  end: d(2025, 5, 29), label: "First trip",  color: "#378add", person: "p" },
          { start: d(2025, 8, 28), end: d(2025, 11, 25), label: "Return trip", color: "#1d9e75", person: "p" },
        ],
        windowDefault: d(2025, 8, 28),
      },
      {
        id: "s5", label: "Four friends, same trip", mode: "quad",
        desc: "All four friends took the same group trip (Feb 1–Mar 22, 50 days), then each returned to the Schengen Area at a different point in the year. <em>Drag the window across the year to compare all four at once.</em>",
        trips: COMBINED_TRIPS,
        windowDefault: d(2025, 7, 15),
      },
      {
        id: "s6", label: "Real travel history (2025–2026)", mode: "single",
        desc: "Trips spent in the Schengen Area from a real honeymoon: Paris/Zagreb (Mar), Croatia/Slovenia (Apr–Jul), Iceland (Sep), Azores/Canary Islands/Madeira (Nov–Dec) in 2025, then Malta (Apr) and Belgium/Luxembourg/The Netherlands (Apr–May) in 2026.",
        trips: [
          { start: d(2025, 3, 14), end: d(2025, 3, 21),  label: "Honeymoon", color: "#378add", person: "p", showLabel: false },
          { start: d(2025, 4, 18), end: d(2025, 7, 2),   label: "Honeymoon", color: "#378add", person: "p", showLabel: false },
          { start: d(2025, 9, 19), end: d(2025, 9, 26),  label: "Honeymoon", color: "#378add", person: "p", showLabel: false },
          { start: d(2025, 11, 27), end: d(2025, 12, 30), label: "Honeymoon", color: "#378add", person: "p", showLabel: false },
          { start: d(2026, 4, 12), end: d(2026, 4, 17),  label: "Honeymoon", color: "#378add", person: "p", showLabel: false },
          { start: d(2026, 4, 23), end: d(2026, 5, 10),  label: "Honeymoon", color: "#378add", person: "p", showLabel: false },
        ],
        windowDefault: d(2025, 9, 1),
      },
    ];

    function initExplorer(container: HTMLElement) {
      const scenarioIdx = parseInt(container.dataset.scenario ?? "0") || 0;
      const isDark = matchMedia("(prefers-color-scheme: dark)").matches;

      const descEl      = container.querySelector<HTMLElement>(".scenario-label")!;
      const canvas      = container.querySelector<HTMLCanvasElement>("canvas")!;
      const slider      = container.querySelector<HTMLInputElement>("input[type=range]")!;
      const dateLabelEl = container.querySelector<HTMLElement>(".window-date-label")!;
      const statsEl     = container.querySelector<HTMLElement>(".stats-container")!;
      const ctx         = canvas.getContext("2d")!;

      const currentScenario: Scenario = SCENARIOS[scenarioIdx];
      let TL_START: Date, TL_END: Date, TL_TOTAL: number;

      function computeRange(trips: Trip[]) {
        const mn = trips.reduce((a, t) => (t.start < a ? t.start : a), trips[0].start);
        const mx = trips.reduce((a, t) => (t.end > a ? t.end : a), trips[0].end);
        return { start: addDays(mn, -PAD), end: addDays(mx, PAD) };
      }

      function countForPerson(trips: Trip[], windowEnd: Date, personKey: string) {
        const windowStart = addDays(windowEnd, -179);
        let count = 0;
        trips.filter((t) => t.person === personKey).forEach((t) => {
          const os = t.start > windowStart ? t.start : windowStart;
          const oe = t.end < windowEnd ? t.end : windowEnd;
          if (oe >= os) count += diffDays(os, oe) + 1;
        });
        return count;
      }

      function countAll(trips: Trip[], windowEnd: Date) {
        const windowStart = addDays(windowEnd, -179);
        let count = 0;
        trips.forEach((t) => {
          const os = t.start > windowStart ? t.start : windowStart;
          const oe = t.end < windowEnd ? t.end : windowEnd;
          if (oe >= os) count += diffDays(os, oe) + 1;
        });
        return count;
      }

      function renderStatsSingle(trips: Trip[], windowEnd: Date) {
        const days = countAll(trips, windowEnd);
        const remaining = Math.max(0, 90 - days);
        statsEl.innerHTML = `
          <div class="stats-single">
            <div class="stat-card">
              <div class="stat-label">Days in window</div>
              <div class="stat-val ${days > 90 ? "danger" : days > 70 ? "warn" : "ok"}">${days}</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Remaining allowance</div>
              <div class="stat-val ${remaining === 0 ? "danger" : remaining < 20 ? "warn" : "ok"}">${remaining}</div>
            </div>
          </div>`;
      }

      function renderStatsQuad(trips: Trip[], windowEnd: Date) {
        const cards = PERSONS.map((p) => {
          const days = countForPerson(trips, windowEnd, p.key);
          const remaining = Math.max(0, 90 - days);
          return `<div class="stat-card" style="border-left-color:${p.color}">
            <div class="stat-label" style="color:${p.color};font-weight:500;">${p.label}</div>
            <div class="stat-val ${days > 90 ? "danger" : days > 70 ? "warn" : "ok"}">${days} <span style="font-size:12px;font-weight:400;color:var(--color-text-secondary)">/ 90</span></div>
            <div class="stat-sublabel">${remaining === 0 ? "No allowance left" : `${remaining} days left`}</div>
          </div>`;
        }).join("");
        statsEl.innerHTML = `<div class="stats-quad">${cards}</div>`;
      }

      function drawTimeline(windowEnd: Date) {
        const sc = currentScenario;
        const trips = sc.trips;
        const isQuad = sc.mode === "quad";
        const W = canvas.width;
        const mL = isQuad ? 68 : 10, mR = 10, mTop = 28;
        const tripH = 20, tripGap = 5;
        const plotW = W - mL - mR;
        const windowStart = addDays(windowEnd, -179);

        const xOf = (dt: Date) => mL + (diffDays(TL_START, dt) / TL_TOTAL) * plotW;

        let numRows: number;
        let getTripRow: (t: Trip, i: number) => number;

        if (isQuad) {
          numRows = PERSONS.length;
          getTripRow = (t) => PERSON_MAP[t.person as PersonKey]?.row ?? 0;
        } else {
          const rowAssign = new Array(trips.length).fill(0);
          const rowEnds: (Date | undefined)[] = [];
          numRows = 1;
          trips.forEach((t, i) => {
            let r = 0;
            while (rowEnds[r] !== undefined && rowEnds[r]! >= t.start) r++;
            rowAssign[i] = r;
            rowEnds[r] = t.end;
            if (r + 1 > numRows) numRows = r + 1;
          });
          getTripRow = (_, i) => rowAssign[i];
        }

        const totalTripH = numRows * tripH + (numRows - 1) * tripGap;
        const tripAreaTop = mTop + 20;
        const axisY = tripAreaTop + totalTripH + 16;
        canvas.height = axisY + 22;

        ctx.clearRect(0, 0, W, canvas.height);

        if (isQuad) {
          ctx.font = "500 11px var(--font-sans,sans-serif)";
          ctx.textAlign = "right";
          PERSONS.forEach((p) => {
            const ty = tripAreaTop + p.row * (tripH + tripGap);
            ctx.fillStyle = p.color;
            ctx.fillText(p.label, mL - 6, ty + tripH / 2 + 4);
          });
        }

        const refOver = isQuad
          ? PERSONS.some((p) => countForPerson(trips, windowEnd, p.key) > 90)
          : countAll(trips, windowEnd) > 90;

        const x0w = Math.max(mL, xOf(windowStart));
        const x1w = Math.min(W - mR, xOf(addDays(windowEnd, 1)));

        // Window overlay
        ctx.fillStyle = refOver
          ? isDark ? "rgba(163,45,45,0.18)" : "rgba(240,149,149,0.15)"
          : isDark ? "rgba(55,138,221,0.12)" : "rgba(55,138,221,0.08)";
        ctx.fillRect(x0w, mTop - 4, x1w - x0w, axisY - (mTop - 4));
        ctx.strokeStyle = refOver
          ? isDark ? "rgba(240,149,149,0.5)" : "rgba(163,45,45,0.35)"
          : isDark ? "rgba(55,138,221,0.4)"  : "rgba(55,138,221,0.35)";
        ctx.lineWidth = 1;
        ctx.strokeRect(x0w, mTop - 4, x1w - x0w, axisY - (mTop - 4));

        // "180-day window" label centered just below the overlay's bottom border
        const winMidX = Math.min(Math.max((x0w + x1w) / 2, mL + 60), W - mR - 60);
        ctx.fillStyle = refOver
          ? isDark ? "rgba(240,149,149,0.6)" : "rgba(163,45,45,0.45)"
          : isDark ? "rgba(130,180,240,0.6)" : "rgba(55,138,221,0.45)";
        ctx.font = "500 10px var(--font-sans,sans-serif)";
        ctx.textAlign = "center";
        ctx.fillText("180-day window", winMidX, axisY + 12);

        // Axis
        ctx.strokeStyle = isDark ? "rgba(255,255,255,0.12)" : "rgba(0,0,0,0.1)";
        ctx.lineWidth = 0.5;
        ctx.beginPath(); ctx.moveTo(mL, axisY); ctx.lineTo(W - mR, axisY); ctx.stroke();

        // Month grid lines + labels
        ctx.font = "11px var(--font-sans,sans-serif)";
        ctx.textAlign = "center";
        const cur = new Date(TL_START); cur.setDate(1);
        while (cur <= TL_END) {
          const x = xOf(cur);
          if (x >= mL && x <= W - mR) {
            ctx.strokeStyle = isDark ? "rgba(255,255,255,0.08)" : "rgba(0,0,0,0.07)";
            ctx.lineWidth = 0.5;
            ctx.beginPath(); ctx.moveTo(x, mTop - 4); ctx.lineTo(x, axisY); ctx.stroke();
            const lx = x + (plotW / TL_TOTAL) * 15;
            if (lx < W - mR - 5) {
              ctx.fillStyle = isDark ? "rgba(255,255,255,0.4)" : "rgba(0,0,0,0.4)";
              ctx.fillText(cur.toLocaleDateString("en-GB", { month: "short" }), lx, axisY + 12);
            }
          }
          cur.setMonth(cur.getMonth() + 1);
        }

        // Trip bars
        trips.forEach((t, i) => {
          const row = getTripRow(t, i);
          const ty = tripAreaTop + row * (tripH + tripGap);
          const x0 = xOf(t.start);
          const x1 = xOf(addDays(t.end, 1));
          const tw = Math.max(x1 - x0, 2);

          ctx.fillStyle = t.color;
          ctx.beginPath(); (ctx as any).roundRect(x0, ty, tw, tripH, 4); ctx.fill();

          const os = t.start > windowStart ? t.start : windowStart;
          const oe = t.end < windowEnd ? t.end : windowEnd;
          if (oe >= os) {
            const xa = xOf(os), xb = xOf(addDays(oe, 1));
            ctx.fillStyle = "rgba(255,255,255,0.22)";
            ctx.beginPath(); (ctx as any).roundRect(xa, ty, xb - xa, tripH, 4); ctx.fill();
          }

          if (tw > 44 && t.showLabel !== false) {
            ctx.fillStyle = "rgba(255,255,255,0.92)";
            ctx.font = "500 11px var(--font-sans,sans-serif)";
            ctx.textAlign = "center";
            ctx.fillText(t.label, x0 + tw / 2, ty + tripH / 2 + 4);
          }
        });

        // Window end dashed line
        const xEnd = xOf(addDays(windowEnd, 1));
        ctx.strokeStyle = isDark ? "rgba(212,83,126,0.85)" : "#d4537e";
        ctx.lineWidth = 1.5;
        ctx.setLineDash([4, 3]);
        ctx.beginPath(); ctx.moveTo(xEnd, mTop - 4); ctx.lineTo(xEnd, axisY); ctx.stroke();
        ctx.setLineDash([]);

        // Window end date above the dashed line
        ctx.fillStyle = "#d4537e";
        ctx.font = "500 10px var(--font-sans,sans-serif)";
        ctx.textAlign = "center";
        const endLx = Math.min(Math.max(xEnd, mL + 30), W - mR - 30);
        ctx.fillText(fmtShort(windowEnd), endLx, mTop - 8);

        // Window start date above the left edge of the window (only when visible)
        const xWinStart = xOf(windowStart);
        if (xWinStart > mL) {
          ctx.fillStyle = isDark ? "rgba(100,160,230,0.8)" : "rgba(55,138,221,0.7)";
          ctx.font = "500 10px var(--font-sans,sans-serif)";
          ctx.textAlign = "left";
          ctx.fillText(fmtShort(windowStart), xWinStart + 2, mTop - 8);
        }
      }

      function init() {
        descEl.innerHTML = currentScenario.desc;

        const range = computeRange(currentScenario.trips);
        TL_START = range.start; TL_END = range.end; TL_TOTAL = diffDays(TL_START, TL_END);
        slider.min = "179"; slider.max = String(TL_TOTAL - 1);
        const def = diffDays(TL_START, currentScenario.windowDefault);
        slider.value = String(Math.min(Math.max(def, 179), TL_TOTAL - 1));

        canvas.width = Math.max(520, container.clientWidth - 42);
        const windowEnd = addDays(TL_START, parseInt(slider.value));
        drawTimeline(windowEnd);

        if (currentScenario.mode === "quad") {
          renderStatsQuad(currentScenario.trips, windowEnd);
        } else {
          renderStatsSingle(currentScenario.trips, windowEnd);
        }

        dateLabelEl.textContent = fmtDate(windowEnd);
      }

      slider.addEventListener("input", () => {
        const windowEnd = addDays(TL_START, parseInt(slider.value));
        drawTimeline(windowEnd);
        if (currentScenario.mode === "quad") {
          renderStatsQuad(currentScenario.trips, windowEnd);
        } else {
          renderStatsSingle(currentScenario.trips, windowEnd);
        }
        dateLabelEl.textContent = fmtDate(windowEnd);
      });

      window.addEventListener("resize", () => {
        canvas.width = Math.max(520, container.clientWidth - 42);
        const windowEnd = addDays(TL_START, parseInt(slider.value));
        drawTimeline(windowEnd);
      });

      init();
    }

    document.querySelectorAll<HTMLElement>(".schengen-explorer[data-scenario]").forEach(initExplorer);
  })();
</script>

